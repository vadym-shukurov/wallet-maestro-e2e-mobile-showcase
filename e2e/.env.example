# ──────────────────────────────────────────────────────
# E2E Test Configuration
# Copy to e2e/.env and fill in your values.
# e2e/.env is gitignored — NEVER commit the real .env.
# This file (.env.example) contains PLACEHOLDERS ONLY.
# ──────────────────────────────────────────────────────

# Expo app name for dev-client launcher (optional — auto-derived from app.json)
# E2E_EXPO_APP_NAME=wdk-starter-react-native

# Run only specific flows (comma-separated, optional)
# E2E_FLOWS=onboarding-navigation,import-wallet

# Run only flows with these tags (comma-separated, optional)
# E2E_TAGS=smoke

# Retry failed flows once (1=default, 0=disabled)
# E2E_RETRY_FAILED=1

# 12-word BIP-39 mnemonic for the import-wallet test (REQUIRED)
# Use placeholder below — replace with your test wallet phrase in e2e/.env
E2E_SEED_PHRASE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Qase API token (from https://app.qase.io/user/api/token)
# QASE_API_TOKEN=

# Qase project code (e.g. RNS)
# QASE_PROJECT=RNS

# Custom test run title (optional)
# QASE_RUN_TITLE=

# Override flow→case ID mapping (optional, JSON)
# QASE_CASE_MAP={"import-wallet":1}
